{
  "campaign_id": "base_2k",
  "version": "1.1.0",
  "title": "Base 2k canonical lab campaign",
  "description": "Canonical single-GPU campaign preserving the upstream 2048-context, 8192-vocab, 300-second fixed-budget spirit through local lab assets.",
  "active": true,
  "comparability_group": "base_2k",
  "primary_metric": {
    "name": "val_bpb",
    "direction": "min",
    "report_precision": 6,
    "tie_threshold": 0.0002
  },
  "budgets": {
    "scout_seconds": 90,
    "main_seconds": 300,
    "confirm_seconds": 1200,
    "replication_seeds": [42, 314],
    "confirm_mode": "longer_budget_then_optional_second_seed"
  },
  "dataset": {
    "source": "local_text_shards_named_like_climbmix",
    "format": "utf8_text_files",
    "builder": "lab.campaigns.builders.base_2k",
    "trust_model": "local_hash_manifest",
    "raw_cache_root": "artifacts/cache/raw/climbmix-400b-shuffle",
    "upstream_reference": "karpathy/climbmix-400b-shuffle",
    "builder_contract": "expects one UTF-8 text file per shard-like filename under raw_cache_root; it does not read parquet directly"
  },
  "tokenizer": {
    "kind": "byte_fallback",
    "vocab_size": 8192,
    "artifact_files": ["tokenizer.json", "merges.txt", "tokenizer.meta.json"],
    "notes": "Deterministic byte-fallback assets written by lab.campaigns.build; not the upstream rustbpe tokenizer."
  },
  "sequence_length": 2048,
  "vocab_size": 8192,
  "splits": {
    "train": {
      "selector": "all_shards_except_explicit_list",
      "exclude_shards": ["shard_06540.parquet", "shard_06541.parquet", "shard_06542.parquet"]
    },
    "search_val": {
      "selector": "explicit_shards",
      "shards": ["shard_06542.parquet"],
      "token_budget": 20971520
    },
    "audit_val": {
      "selector": "explicit_shards",
      "shards": ["shard_06541.parquet"],
      "token_budget": 4194304
    },
    "locked_val": {
      "selector": "explicit_shards",
      "shards": ["shard_06540.parquet"],
      "token_budget": 4194304
    }
  },
  "assets": {
    "root": "artifacts/cache/campaigns/base_2k",
    "tokenizer_manifest": "tokenizer.manifest.json",
    "pretok_manifest": "pretok.manifest.json",
    "packed_manifest": "packed.manifest.json"
  },
  "search_space": {
    "module": "research.dense_gpt.search_space",
    "profile": "base_2k"
  },
  "promotion": {
    "scout_to_main_min_delta": 0.0004,
    "main_to_confirm_min_delta": 0.0003,
    "champion_min_delta": 0.0002,
    "allow_complexity_tie_break": true
  },
  "retention": {
    "discarded": "summary+logs_only",
    "promoted": "full_artifacts",
    "champion": "full_artifacts_plus_archive",
    "crash": "summary+logs+exemplar"
  },
  "runtime": {
    "allowed_device_profiles": ["rtx_pro_6000_96gb", "generic_single_gpu_nvidia"],
    "preferred_dtype": "bfloat16",
    "backend_policy": "benchmark_and_cache",
    "compile_cache_policy": "by_device_profile+shape_family+backend",
    "max_peak_vram_gb": 92
  },
  "baseline": {
    "name": "upstream_parity_seed",
    "source": "karpathy/autoresearch",
    "target_metric": "match sequence-length, vocab-size, budget, and val_bpb semantics rather than exact floating point identity",
    "notes": "Use as the upstream truth anchor and regression guard. Data and tokenizer mechanics are intentionally not identical."
  }
}
