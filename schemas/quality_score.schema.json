{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QualityScore",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "updated_at",
    "phase",
    "scores"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 4
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
