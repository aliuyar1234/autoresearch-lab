{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "campaign_id",
    "lane",
    "family",
    "kind",
    "status",
    "created_at",
    "generator",
    "parent_ids",
    "hypothesis",
    "rationale",
    "config_overrides",
    "complexity_cost",
    "expected_direction",
    "tags",
    "idea_signature",
    "mutation_paths",
    "retrieval_event_id",
    "evidence",
    "generation_context"
  ],
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "lane": {
      "type": "string",
      "enum": [
        "scout",
        "main",
        "confirm"
      ]
    },
    "family": {
      "type": "string",
      "enum": [
        "baseline",
        "exploit",
        "ablation",
        "combine",
        "novel",
        "manual"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "structured",
        "code_patch",
        "manual"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "discarded",
        "promoted",
        "archived",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "parent_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "config_overrides": {
      "type": "object"
    },
    "complexity_cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "expected_direction": {
      "type": "string",
      "enum": [
        "improve",
        "neutral",
        "exploratory"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "idea_signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "mutation_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retrieval_event_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "memory_id",
          "record_type",
          "role",
          "score",
          "reason",
          "source_ref"
        ],
        "properties": {
          "memory_id": {
            "type": "string"
          },
          "record_type": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "supporting_precedent",
              "warning",
              "combination_parent",
              "report_note"
            ]
          },
          "score": {
            "type": "number"
          },
          "reason": {
            "type": "string"
          },
          "source_ref": {
            "type": "string"
          }
        }
      }
    },
    "generation_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_selector_reason",
        "anchor_experiment_ids",
        "blocked_idea_signatures",
        "retrieval_event_id",
        "selection_rank",
        "selection_score"
      ],
      "properties": {
        "family_selector_reason": {
          "type": "string"
        },
        "anchor_experiment_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_idea_signatures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retrieval_event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "selection_rank": {
          "type": [
            "integer",
            "null"
          ]
        },
        "selection_score": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "novelty_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "guardrails": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "config_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_experiments": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "code_patch": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "target_files",
        "base_commit",
        "acceptance_summary"
      ],
      "properties": {
        "target_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "base_commit": {
          "type": "string"
        },
        "patch_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "acceptance_summary": {
          "type": "string"
        },
        "worktree_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "source_experiments": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}
