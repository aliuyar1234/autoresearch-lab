{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "campaign_id",
    "lane",
    "family",
    "kind",
    "status",
    "created_at",
    "generator",
    "parent_ids",
    "hypothesis",
    "rationale",
    "config_overrides",
    "complexity_cost",
    "expected_direction",
    "tags"
  ],
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "lane": {
      "type": "string",
      "enum": [
        "scout",
        "main",
        "confirm"
      ]
    },
    "family": {
      "type": "string",
      "enum": [
        "baseline",
        "exploit",
        "ablation",
        "combine",
        "novel",
        "manual"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "structured",
        "code_patch",
        "manual"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "discarded",
        "promoted",
        "archived",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "parent_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "config_overrides": {
      "type": "object"
    },
    "complexity_cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "expected_direction": {
      "type": "string",
      "enum": [
        "improve",
        "neutral",
        "exploratory"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "novelty_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "guardrails": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "config_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_experiments": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "code_patch": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "target_files",
        "base_commit",
        "acceptance_summary"
      ],
      "properties": {
        "target_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "base_commit": {
          "type": "string"
        },
        "patch_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "acceptance_summary": {
          "type": "string"
        },
        "worktree_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
