{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentSchedulerPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "campaign_id",
    "review_state",
    "family_weights",
    "preferred_families",
    "blocked_families",
    "rationale",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "review_state": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed"
      ]
    },
    "family_weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "type": "number"
        },
        "exploit": {
          "type": "number"
        },
        "ablation": {
          "type": "number"
        },
        "combine": {
          "type": "number"
        },
        "novel": {
          "type": "number"
        }
      }
    },
    "preferred_families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "baseline",
          "exploit",
          "ablation",
          "combine",
          "novel"
        ]
      }
    },
    "blocked_families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "baseline",
          "exploit",
          "ablation",
          "combine",
          "novel"
        ]
      }
    },
    "max_complexity_cost": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "maximum": 9
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
